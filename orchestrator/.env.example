# PostgreSQL — credentials from root .env, only host differs for local dev
# Must match POSTGRES_USER / POSTGRES_PASSWORD from root .env
# POSTGRES_HOST=localhost to target the Docker postgres exposed locally
POSTGRES_USER=llmgrill
POSTGRES_PASSWORD=
POSTGRES_HOST=localhost
POSTGRES_DB=llmgrill

POLL_INTERVAL_SECONDS=10

API_KEY=

# Terraform / Scaleway
ORCHESTRATOR_URL=http://your-orchestrator-public-ip:8000
HF_TOKEN=hf_xxx
GPU_ZONE=fr-par-2

# Scaleway Object Storage
SCW_BUCKET=llm-grill-platform
SCW_REGION=fr-par
SCW_ACCESS_KEY=xxx
SCW_SECRET_KEY=xxx
