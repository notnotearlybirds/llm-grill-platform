# PostgreSQL
POSTGRES_USER=llmgrill
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_DB=llmgrill

# Orchestrator — public HTTPS URL (used by GPU VMs to call back)
ORCHESTRATOR_URL=https://orchestrator.example.com

# API key protecting all mutating endpoints (generate with: openssl rand -hex 32)
API_KEY=

# HuggingFace token for model downloads
HF_TOKEN=

# Scaleway credentials (Object Storage + Terraform-driven GPU provisioning)
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_DEFAULT_PROJECT_ID=
SCW_DEFAULT_ORGANIZATION_ID=
SCW_BUCKET=llmgrill-results
SCW_REGION=fr-par

# Scaleway GPU zone for Terraform-provisioned nodes
GPU_ZONE=fr-par-2

# Comma-separated SSH public keys injected on every provisioned GPU VM (for debug)
# Leave empty to disable SSH access.
SSH_PUBLIC_KEYS=

# Force-destroy a node if its run stays in "running" longer than this (minutes)
RUN_RUNNING_TIMEOUT_MINUTES=60
